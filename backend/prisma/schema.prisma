// backend/prisma/schema.prisma
// Branch: feature/farmer-harvest

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  AGENT 
// ═══════════════════════════════════════════════════════════════
model Agent {
  walletAddress   String   @id          
  name            String
  role            AgentRole
  phone           String?
  email           String?  @unique
  physicalAddress String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  coffeeLots CoffeeLot[] @relation("FarmerLots")

  @@map("agents")
}

enum AgentRole {
  ADMIN
  FARMER
  COOPERATIVE
  PROCESSOR
  EXPORTER
  ROASTERY
}

// ═══════════════════════════════════════════════════════════════
//  COFFEE LOT
// ═══════════════════════════════════════════════════════════════
model CoffeeLot {
  // --- Fields từ Luồng 1 (CREATE) ---
  lotId         BigInt   @id           
  qrCode        String   @unique      
  currentStatus String   @default("CREATED") 
  currentActor  String                
  farmerAddress String                
  initTxHash    String?               
  createdAt     DateTime @default(now()) 

  // --- Relations ---
  farmer        Agent          @relation("FarmerLots", fields: [farmerAddress], references: [walletAddress])
  stageDetails  LotStageDetail[]
  timelines     LotTimeline[]

  @@map("coffee_lots")
}

// ═══════════════════════════════════════════════════════════════
//  LOT STAGE DETAIL 
// ═══════════════════════════════════════════════════════════════
model LotStageDetail {
  id                 Int      @id @default(autoincrement())
  lotId              BigInt
  stageName          String   
  stageDataPayload   Json     
  txHash             String?  
  blockchainTimestamp DateTime? 
  createdAt          DateTime @default(now())

  lot CoffeeLot @relation(fields: [lotId], references: [lotId])

  @@map("lot_stage_details")
}

// ═══════════════════════════════════════════════════════════════
//  LOT TIMELINE
// ═══════════════════════════════════════════════════════════════
model LotTimeline {
  id          Int      @id @default(autoincrement())
  lotId       BigInt
  status      String   
  description String   
  txHash      String?
  createdAt   DateTime @default(now())

  lot CoffeeLot @relation(fields: [lotId], references: [lotId])

  @@map("lot_timelines")
}
